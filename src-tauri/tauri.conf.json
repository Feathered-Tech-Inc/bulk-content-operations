{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Bulk Content Operations",
    "version": "1.0.5",
    "identifier": "com.featheredtech.bulkcontentoperations",
    "build": {
        "frontendDist": "../ui"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Bulk Content Operations",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": [
            "resources/node/node",
            "resources/worker/publish-worker.js"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "hardenedRuntime": true,
            "entitlements": "entitlements.plist"
        },
        "android": {
            "debugApplicationIdSuffix": ".debug"
        }
    }
}
